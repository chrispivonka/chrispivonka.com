# Google OAuth2 credentials
# Create at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: https://kittycam.chrispivonka.com/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=your-client-secret

# Cookie encryption secret (must be 32 bytes, base64-encoded)
# Generate with: python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
OAUTH2_PROXY_COOKIE_SECRET=generate-me
